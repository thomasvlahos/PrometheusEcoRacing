static void lcd_write(uint8_t data)
{
    HAL_I2C_Master_Transmit(&hi2c1, LCD_ADDR, &data, 1, 100);
}

static void lcd_send_nibble(uint8_t nibble, uint8_t control)
{
    uint8_t data = nibble | control | LCD_BACKLIGHT;

    lcd_write(data);
    lcd_toggle_enable(data);
}

static void lcd_send_cmd(uint8_t cmd)
{
    uint8_t upper = cmd & 0xF0;
    uint8_t lower = (cmd << 4) & 0xF0;

    lcd_send_nibble(upper, 0);
    lcd_send_nibble(lower, 0);
}

static void lcd_send_data(uint8_t data)
{
    uint8_t upper = data & 0xF0;
    uint8_t lower = (data << 4) & 0xF0;

    lcd_send_nibble(upper, LCD_RS);
    lcd_send_nibble(lower, LCD_RS);
}

static void lcd_print(char *str)
{
    while(*str)
    {
        lcd_send_data(*str++);
    }
}

static void lcd_init(void)
{
    HAL_Delay(50);

    // Send 0x30 three times (only high nibble)
    lcd_send_nibble(0x30, 0);
    HAL_Delay(5);

    lcd_send_nibble(0x30, 0);
    HAL_Delay(5);

    lcd_send_nibble(0x30, 0);
    HAL_Delay(5);

    // Set 4-bit mode
    lcd_send_nibble(0x20, 0);
    HAL_Delay(5);

    // Now normal commands
    lcd_send_cmd(0x28); // 4-bit, 2 lines
    lcd_send_cmd(0x08); // display off
    lcd_send_cmd(0x01); // clear
    HAL_Delay(2);

    lcd_send_cmd(0x06); // entry mode
    lcd_send_cmd(0x0C); // display on
}

static void lcd_toggle_enable(uint8_t data)
{
    lcd_write(data | LCD_ENABLE);
    HAL_Delay(1);

    lcd_write(data & ~LCD_ENABLE);
    HAL_Delay(1);
}

void I2C_Scan(void)
{
    for(uint8_t addr = 1; addr < 128; addr++)
    {
        if(HAL_I2C_IsDeviceReady(&hi2c1, addr << 1, 1, 10) == HAL_OK)
        {
            for(int i=0;i<addr;i++)
            {
                HAL_GPIO_TogglePin(GPIOC, GPIO_PIN_13);
                HAL_Delay(200);
            }

            HAL_Delay(2000);
        }
    }
}

