/*
 * Sends two floats (little endian) in one CAN frame (8 bytes total)
 * stdID  : 11-bit standard CAN ID
 * value1 : first float
 * value2 : second float
 */
void CAN_SendFloat(uint16_t stdID, float value1, float value2)
{
    CAN_TxHeaderTypeDef txHeader;
    uint8_t txData[8];
    uint32_t txMailbox;

    /* Configure CAN header */
    txHeader.StdId = stdID;            // 11-bit ID
    txHeader.ExtId = 0;                // Not used (standard frame)
    txHeader.IDE = CAN_ID_STD;         // Standard ID
    txHeader.RTR = CAN_RTR_DATA;       // Data frame
    txHeader.DLC = 8;                  // 8 data bytes
    txHeader.TransmitGlobalTime = DISABLE;

    /*
     * Copy floats into byte array.
     * STM32 is little endian, so memcpy keeps correct byte order.
     */
    memcpy(&txData[0], &value1, 4);
    memcpy(&txData[4], &value2, 4);

    /* Send only if mailbox available */
    if (HAL_CAN_GetTxMailboxesFreeLevel(&hcan) > 0)
    {
        HAL_CAN_AddTxMessage(&hcan, &txHeader, txData, &txMailbox);
    }
}

/*
 * Reads CAN frame with specific Standard ID
 * Returns two floats directly inside struct
 *
 * If message not available or wrong ID,
 * returns zeros (0.0f, 0.0f)
 */
CAN_FloatPacket CAN_ReadFloat(uint16_t expectedID)
{
    CAN_FloatPacket packet = {0.0f, 0.0f};  // default return

    CAN_RxHeaderTypeDef rxHeader;
    uint8_t rxData[8];

    /* Check if message available in FIFO0 */
    if (HAL_CAN_GetRxFifoFillLevel(&hcan, CAN_RX_FIFO0) > 0)
    {
        HAL_CAN_GetRxMessage(&hcan, CAN_RX_FIFO0, &rxHeader, rxData);

        /* Check if correct Standard ID */
        if (rxHeader.StdId == expectedID && rxHeader.DLC == 8)
        {
            /*
             * Convert 8 received bytes into two floats
             * STM32 is little endian, so memcpy restores correctly
             */
            memcpy(&packet.value1, &rxData[0], 4);
            memcpy(&packet.value2, &rxData[4], 4);
        }
    }

    return packet;
}

